---
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, image, jsonLd } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;

const { version } = JSON.parse(
  readFileSync(resolve(process.cwd(), "package.json"), "utf-8"),
);
const configPath = resolve(process.cwd(), ".site-config");
const configContent = existsSync(configPath)
  ? readFileSync(configPath, "utf-8")
  : "";
const aiModel =
  configContent.match(/^AI_MODEL=(.+)$/m)?.[1]?.trim() ?? "Claude";
const generator = `Anglesite ${version} (${aiModel}, ${Astro.generator})`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#11131a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fdfdfd" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-license">
        <a href="/" class="footer-link">crontab clock</a>
        <span>by</span>
        <a href="https://dwk.io/" class="footer-link" rel="me">David W. Keith</a>
        <span>is licensed under</span>
        <span class="footer-break" aria-hidden="true"></span>
        <a
          href="https://creativecommons.org/licenses/by/4.0/"
          class="footer-link"
          rel="license"
        >
          Creative Commons Attribution 4.0 International
        </a>
        <span class="cc-icons" aria-hidden="true">
          <svg viewBox="0 0 64 64" role="img" aria-hidden="true">
            <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"></circle>
            <path d="M26 41c-5 0-9-4-9-9s4-9 9-9c2 0 4 .6 5.6 1.8l-2.2 3c-.9-.7-2-1-3.4-1-3 0-5 2.3-5 5.2 0 2.9 2 5.2 5 5.2 1.4 0 2.7-.5 3.6-1.3l2.1 2.8C30.4 40.3 28.3 41 26 41z" fill="currentColor"></path>
            <path d="M40 41c-5 0-9-4-9-9s4-9 9-9c2 0 4 .6 5.6 1.8l-2.2 3c-.9-.7-2-1-3.4-1-3 0-5 2.3-5 5.2 0 2.9 2 5.2 5 5.2 1.4 0 2.7-.5 3.6-1.3l2.1 2.8C44.4 40.3 42.3 41 40 41z" fill="currentColor"></path>
          </svg>
          <svg viewBox="0 0 64 64" role="img" aria-hidden="true">
            <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"></circle>
            <circle cx="32" cy="22" r="6" fill="currentColor"></circle>
            <path d="M24 50v-4h4V30h8v16h4v4H24z" fill="currentColor"></path>
          </svg>
        </span>
      </div>
      <div class="footer-badge">
        <a
          href="https://www.thegreenwebfoundation.org/green-web-check/?url=crontab.dwk.io"
          class="badge-link"
        >
          <img
            src="https://app.greenweb.org/api/v3/greencheckimage/crontab.dwk.io?nocache=true"
            alt="Green Hosting badge from The Green Web Foundation"
            width="200"
            height="95"
            loading="lazy"
          />
        </a>
      </div>
    </footer>
  </body>
</html>
