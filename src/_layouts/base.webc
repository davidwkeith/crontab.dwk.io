<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title @text="$data.title ? `${$data.title} — ${$data.site.title}` : $data.site.title"></title>
    
    <meta webc:is="head-meta" />
    <link webc:is="head-link" />
    <script webc:is="head-js"></script>
    <template webc:if="$data.site.hasTwitter">
      <!-- Twitter Card meta tags (conditionally rendered based on $data.site.hasTwitter in site.js) -->
      <!-- Consider using Fediverse or Bluesky alternatives for social sharing. -->
    </template>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
      <nav webc:if="$data.site.hasNavigation">
        <a webc:for="item in $data.navigation" :href="item.url" @text="item.text"></a>
      </nav>
    </header>
    <main id="main-content">
      <slot><template webc:nokeep @raw="this.content"></template></slot>
      <div webc:is="webmentions" webc:if="$data.site.hasWebmentions"></div>
    </main>
    <footer class="site-footer">
      <div class="footer-license">
        <a href="/" class="footer-link">crontab clock</a>
        <span>by</span>
        <a href="https://dwk.io/" class="footer-link">David W. Keith</a>
        <span>is licensed under</span>
        <span class="footer-break" aria-hidden="true"></span>
        <a
          href="https://creativecommons.org/licenses/by/4.0/"
          class="footer-link"
          rel="license"
        >
          Creative Commons Attribution 4.0 International
        </a>
        <span class="cc-icons" aria-hidden="true">
          <svg viewBox="0 0 64 64" role="img" aria-hidden="true">
            <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"></circle>
            <path d="M26 41c-5 0-9-4-9-9s4-9 9-9c2 0 4 .6 5.6 1.8l-2.2 3c-.9-.7-2-1-3.4-1-3 0-5 2.3-5 5.2 0 2.9 2 5.2 5 5.2 1.4 0 2.7-.5 3.6-1.3l2.1 2.8C30.4 40.3 28.3 41 26 41z" fill="currentColor"></path>
            <path d="M40 41c-5 0-9-4-9-9s4-9 9-9c2 0 4 .6 5.6 1.8l-2.2 3c-.9-.7-2-1-3.4-1-3 0-5 2.3-5 5.2 0 2.9 2 5.2 5 5.2 1.4 0 2.7-.5 3.6-1.3l2.1 2.8C44.4 40.3 42.3 41 40 41z" fill="currentColor"></path>
          </svg>
          <svg viewBox="0 0 64 64" role="img" aria-hidden="true">
            <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"></circle>
            <circle cx="32" cy="22" r="6" fill="currentColor"></circle>
            <path d="M24 50v-4h4V30h8v16h4v4H24z" fill="currentColor"></path>
          </svg>
        </span>
      </div>
      <div class="footer-badge">
        <a
          href="https://www.thegreenwebfoundation.org/green-web-check/?url=crontab.dwk.io"
          class="badge-link"
        >
          <img
            src="https://app.greenweb.org/api/v3/greencheckimage/crontab.dwk.io?nocache=true"
            alt="Green Hosting badge from The Green Web Foundation"
            width="200"
            height="95"
            loading="lazy"
          >
        </a>
      </div>
    </footer>
    <style webc:keep @raw="getBundle('css', 'defer')"></style>
		<script webc:keep @raw="getBundle('js', 'defer')"></script>
    <script webc:if="$data.site.hasPWA">
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(registration => {
              console.log('Service Worker registered: ', registration);
            })
            .catch(error => {
              console.error('Service Worker registration failed: ', error);
            });
        });
      }
    </script>
  </body>
</html>
